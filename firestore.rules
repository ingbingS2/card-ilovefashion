rules_version = '2';

// 개발용 기본 규칙. 프로덕션에서는 반드시 인증 기반으로 강화할 것.
service cloud.firestore {
  match /databases/{database}/documents {

    // 카드뉴스 컬렉션: 개발 단계에서는 읽기 허용, 쓰기는 서버(Admin SDK)만 권장.
    match /cardnews/{docId} {
      allow read: if true;
      // TODO(prod): request.auth != null 등으로 제한. 현재는 백엔드 Admin SDK 를 통한 쓰기만 가정.
      allow write: if false;
    }

    // 랭킹 스냅샷: Phase 2 사이트가 클라이언트에서 읽음. 쓰기는 크롤러(Admin SDK)만.
    match /rankings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 상품 상세(후기 포함): 읽기 공개, 쓰기 차단 — Admin SDK 크롤러는 규칙 미적용
    match /products/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 그 외 경로는 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
